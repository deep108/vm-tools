# .kamal/secrets — runtime secrets read by Kamal at deploy time.
# This file is the EXAMPLE/template. Real values go in .kamal/secrets (gitignored)
# or .kamal/secrets.age (encrypted, committed).
#
# At minimum, KAMAL_REGISTRY_PASSWORD must be set — Kamal uses it to push/pull
# the image to/from your container registry.
#
# Default architecture: Google Artifact Registry with a narrowly-scoped service
# account. KAMAL_REGISTRY_PASSWORD = base64-encoded JSON key contents.
#
# To populate from a fresh GCP service-account JSON file:
#   B64=$(base64 -i path/to/key.json | tr -d '\n')
#   echo "KAMAL_REGISTRY_PASSWORD=$B64" > .kamal/secrets
#   chmod 600 .kamal/secrets
#   # Then encrypt and delete plaintext:
#   age -p < .kamal/secrets > .kamal/secrets.age
#   shred -u .kamal/secrets

KAMAL_REGISTRY_PASSWORD=put-base64-encoded-service-account-json-here

# App-level secrets (mirror these into config/deploy.yml's env.secret list):
# READWISE_API_TOKEN=...
# ANTHROPIC_API_KEY=...
