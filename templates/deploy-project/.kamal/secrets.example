# .kamal/secrets — runtime secrets injected into the deployed container.
# This file is the EXAMPLE/template. Copy to plaintext, fill in real values,
# encrypt with age, then delete the plaintext.
#
# Workflow:
#   cp .kamal/secrets.example /tmp/secrets-plain
#   $EDITOR /tmp/secrets-plain                 # fill in real values
#   age -p < /tmp/secrets-plain > .kamal/secrets.age   # prompts for passphrase
#   shred -u /tmp/secrets-plain
#
# The encrypted .kamal/secrets.age IS committed to the repo.
# The plaintext .kamal/secrets is gitignored and only exists transiently
# during deploy (created by bin/deploy, shredded on exit).

export EXAMPLE_API_TOKEN="put-real-token-here"
# add more secrets as the app needs them, mirroring config/deploy.yml's env.secret list
