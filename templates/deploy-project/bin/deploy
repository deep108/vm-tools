#!/usr/bin/env bash
# Deploy __PROJECT__ to its Hetzner host.
#
# Usage:
#   bin/deploy <signed-tag>
#
# The tag must already be signed (`git tag -s`) and verified before invoking
# this script. The canonical command is:
#   git verify-tag $TAG && bin/deploy $TAG
#
# Verifying inline here would mean a compromised bin/deploy could skip the
# check. Typing it as a separate command keeps the gate outside this script.

set -euo pipefail

TAG="${1:-}"
if [[ -z "$TAG" ]]; then
    echo "Usage: bin/deploy <signed-tag>"
    echo "  e.g.: bin/deploy v0.1.4"
    exit 1
fi

SECRETS_AGE_FILE=".kamal/secrets.age"
SECRETS_PLAIN_FILE=".kamal/secrets"

# --- Pre-flight checks ------------------------------------------------------

# Make sure the tag exists locally
if ! git rev-parse "refs/tags/$TAG" >/dev/null 2>&1; then
    echo "Error: tag '$TAG' not found locally. Did you 'git fetch --tags'?"
    exit 1
fi

# --- Check out the signed tag -----------------------------------------------
# We deploy from the exact tagged state, not from the working tree.

echo "Checking out tag $TAG..."
git checkout "$TAG"

# --- Decrypt secrets if present, deploy, shred plaintext on exit ------------
# Secrets are optional: an app with no env.secret entries in config/deploy.yml
# doesn't need a secrets file. If $SECRETS_AGE_FILE exists, we decrypt it for
# Kamal to read at deploy time and shred the plaintext when the script exits.

if [[ -f "$SECRETS_AGE_FILE" ]]; then
    trap 'shred -u "$SECRETS_PLAIN_FILE" 2>/dev/null || rm -f "$SECRETS_PLAIN_FILE"' EXIT
    echo "Decrypting secrets (you'll be prompted for the deploy passphrase)..."
    age -d "$SECRETS_AGE_FILE" > "$SECRETS_PLAIN_FILE"
    chmod 600 "$SECRETS_PLAIN_FILE"
else
    echo "No $SECRETS_AGE_FILE — deploying without secrets."
fi

# Placeholder for Kamal's required registry password — never used because we
# don't push (builder.remote keeps the image on the target server).
export KAMAL_REGISTRY_PASSWORD="${KAMAL_REGISTRY_PASSWORD:-unused-builder-remote}"

echo "Deploying $TAG..."
kamal deploy

echo "✓ __PROJECT__ $TAG deployed"
