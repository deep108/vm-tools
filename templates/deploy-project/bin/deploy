#!/usr/bin/env bash
# Deploy __PROJECT__ to its Hetzner host.
#
# Usage:
#   bin/deploy <signed-tag>
#
# The tag must already be signed (`git tag -s`) and verified before invoking
# this script. The canonical command is:
#   git verify-tag $TAG && bin/deploy $TAG
#
# Verifying inline here would mean a compromised bin/deploy could skip the
# check. Typing it as a separate command keeps the gate outside this script.

set -euo pipefail

TAG="${1:-}"
if [[ -z "$TAG" ]]; then
    echo "Usage: bin/deploy <signed-tag>"
    echo "  e.g.: bin/deploy v0.1.4"
    exit 1
fi

SECRETS_AGE_FILE=".kamal/secrets.age"
SECRETS_PLAIN_FILE=".kamal/secrets"
LOGGED_IN_REGISTRY=""

# Cleanup: shred decrypted secrets, log out of registry
cleanup() {
    [[ -f "$SECRETS_PLAIN_FILE" ]] && { shred -u "$SECRETS_PLAIN_FILE" 2>/dev/null || rm -f "$SECRETS_PLAIN_FILE"; }
    [[ -n "$LOGGED_IN_REGISTRY" ]] && docker logout "$LOGGED_IN_REGISTRY" >/dev/null 2>&1 || true
}
trap cleanup EXIT

# --- Pre-flight checks ------------------------------------------------------

if ! git rev-parse "refs/tags/$TAG" >/dev/null 2>&1; then
    echo "Error: tag '$TAG' not found locally. Did you 'git fetch --tags'?"
    exit 1
fi

# --- Check out the signed tag -----------------------------------------------
# Deploy from the exact tagged state, not from the working tree.

echo "Checking out tag $TAG..."
git checkout "$TAG"

# --- Decrypt secrets, source them, log in to registry, deploy --------------

if [[ -f "$SECRETS_AGE_FILE" ]]; then
    echo "Decrypting secrets (you'll be prompted for the deploy passphrase)..."
    age -d "$SECRETS_AGE_FILE" > "$SECRETS_PLAIN_FILE"
    chmod 600 "$SECRETS_PLAIN_FILE"
fi

if [[ -f "$SECRETS_PLAIN_FILE" ]]; then
    set -a
    # shellcheck disable=SC1090
    source "$SECRETS_PLAIN_FILE"
    set +a
fi

# Docker login on dev VM so buildx forwards creds to remote buildkit.
# (Kamal's own docker login runs on the deploy target only.)
if [[ -n "${KAMAL_REGISTRY_PASSWORD:-}" ]] && [[ -f "config/deploy.yml" ]]; then
    REGISTRY_SERVER=$(awk '/^registry:/{in_r=1;next} /^[a-zA-Z]/{in_r=0} in_r && /^  server:/{print $2; exit}' config/deploy.yml)
    REGISTRY_USERNAME=$(awk '/^registry:/{in_r=1;next} /^[a-zA-Z]/{in_r=0} in_r && /^  username:/{print $2; exit}' config/deploy.yml)
    if [[ -n "${REGISTRY_SERVER:-}" && -n "${REGISTRY_USERNAME:-}" ]]; then
        echo "Logging in to $REGISTRY_SERVER..."
        echo "$KAMAL_REGISTRY_PASSWORD" | docker login "$REGISTRY_SERVER" -u "$REGISTRY_USERNAME" --password-stdin >/dev/null
        LOGGED_IN_REGISTRY="$REGISTRY_SERVER"
    fi
fi

# APP_VERSION gets baked into the image via builder.args (see config/deploy.yml)
# so the running container can report what it was deployed from. We use the
# tag the user passed — bin/deploy is only ever invoked with a signed tag.
export APP_VERSION="$TAG"

echo "Deploying $TAG..."
kamal deploy

echo "✓ __PROJECT__ $TAG deployed"
