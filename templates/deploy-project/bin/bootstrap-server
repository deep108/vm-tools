#!/usr/bin/env bash
# One-time setup of the Hetzner server for hosting __PROJECT__.
# Idempotent — safe to re-run if interrupted or partial.
#
# What it does (in order):
#   1. Creates a kamal-__PROJECT__ user on Hetzner (no sudo, in docker group)
#   2. Installs the deploy SSH key into kamal-__PROJECT__'s authorized_keys
#   3. Removes the admin user (HETZNER_ADMIN_USER) from the docker group, so only
#      kamal-* users can reach the docker socket
#   4. Decrypts secrets, runs `docker login` on the dev VM (so buildx can forward
#      creds to the remote buildkit), then runs `kamal setup`
#
# Prerequisites:
#   - config/deploy.yml configured with this project's server, hostname, etc.
#   - .kamal/secrets.age encrypted with a deploy passphrase (or .kamal/secrets
#     present in plaintext for first-time setup; should be encrypted afterward)
#   - HETZNER_HOST set below or via env var
#   - SSH access to Hetzner as HETZNER_ADMIN_USER (provision-vm.sh sets this up)

set -euo pipefail

# Print a helpful message on any failure. The script is idempotent — most
# steps re-run cleanly. Decrypted secrets are still shredded by the EXIT trap.
err_trap() {
    local exit_code=$?
    echo ""
    echo "✗ bootstrap-server failed at line $1 (exit $exit_code)."
    echo "  This script is idempotent: fix the underlying issue and re-run."
    echo "  Already-applied state (kamal user, group membership, etc.) stays as-is."
}
trap 'err_trap $LINENO' ERR

# --- Configuration -----------------------------------------------------------
# These values are populated by the template substitution recipe in
# templates/deploy-project/README.md. Each one can be overridden at runtime
# via env var if you need to bootstrap a different host without re-templating.

HETZNER_HOST="${HETZNER_HOST:-__HETZNER_HOST__}"
HETZNER_ADMIN_USER="${HETZNER_ADMIN_USER:-__ADMIN_USER__}"
DEPLOY_KEY="${DEPLOY_KEY:-${HOME}/.ssh/id_ed25519}"
KAMAL_USER="kamal-__PROJECT__"
SECRETS_AGE_FILE=".kamal/secrets.age"
SECRETS_PLAIN_FILE=".kamal/secrets"

# --- Pre-flight checks -------------------------------------------------------

if [[ "$HETZNER_HOST" == *"__"* ]]; then
    echo "Error: HETZNER_HOST is still a placeholder."
    echo "  Set via env var: HETZNER_HOST=1.2.3.4 bin/bootstrap-server"
    echo "  Or edit bin/bootstrap-server and replace __HETZNER_HOST__"
    exit 1
fi

if [[ ! -f "${DEPLOY_KEY}.pub" ]]; then
    echo "Error: deploy public key ${DEPLOY_KEY}.pub not found."
    echo "  Generate one: ssh-keygen -t ed25519 -f ${DEPLOY_KEY} -N ''"
    exit 1
fi

DEPLOY_PUBKEY="$(cat "${DEPLOY_KEY}.pub")"
REGISTRY_SERVER=""
REGISTRY_USERNAME=""
LOGGED_IN_REGISTRY=""

# Cleanup on any exit: shred decrypted secrets, log out of registry
cleanup() {
    [[ -f "$SECRETS_PLAIN_FILE" ]] && { shred -u "$SECRETS_PLAIN_FILE" 2>/dev/null || rm -f "$SECRETS_PLAIN_FILE"; }
    [[ -n "$LOGGED_IN_REGISTRY" ]] && docker logout "$LOGGED_IN_REGISTRY" >/dev/null 2>&1 || true
}
trap cleanup EXIT

# --- Hetzner-side pre-flight (read-only checks before any state changes) ----

echo "Pre-flight checks against $HETZNER_HOST..."

# 1. Can we SSH as the admin user at all?
if ! ssh -o BatchMode=yes -o ConnectTimeout=10 \
        "${HETZNER_ADMIN_USER}@${HETZNER_HOST}" true 2>/dev/null; then
    echo "Error: cannot SSH to ${HETZNER_ADMIN_USER}@${HETZNER_HOST}."
    echo "  Verify your SSH key is installed in"
    echo "  /home/${HETZNER_ADMIN_USER}/.ssh/authorized_keys on the Hetzner box."
    exit 1
fi
echo "    ✓ SSH as $HETZNER_ADMIN_USER OK"

# 2. If the per-project kamal user already exists, ensure its installed deploy
# key matches the one this machine has. Mismatch implies another machine
# bootstrapped this project — abort to avoid clobbering its access.
existing_pubkey=$(ssh "${HETZNER_ADMIN_USER}@${HETZNER_HOST}" \
    "sudo cat /home/${KAMAL_USER}/.ssh/authorized_keys 2>/dev/null" || true)
if [[ -n "$existing_pubkey" ]]; then
    # Strip trailing whitespace/comments mismatch by comparing key body only
    if [[ "${existing_pubkey%[[:space:]]*}" == "${DEPLOY_PUBKEY%[[:space:]]*}" ]]; then
        echo "    ✓ $KAMAL_USER already provisioned with this deploy key (idempotent re-run)"
    else
        echo "    ✗ $KAMAL_USER exists on Hetzner with a DIFFERENT SSH key:"
        echo "         existing (first 50 chars): ${existing_pubkey:0:50}..."
        echo "         our key  (first 50 chars): ${DEPLOY_PUBKEY:0:50}..."
        echo ""
        echo "      Likely another machine bootstrapped this project. Aborting."
        echo "      To proceed, either: (a) use the matching deploy key on this"
        echo "      machine, or (b) manually verify and replace the key in"
        echo "      /home/${KAMAL_USER}/.ssh/authorized_keys on Hetzner."
        exit 1
    fi
fi

# 3. Best-effort hostname-collision warning. kamal-proxy's label format isn't
# stable across versions, so this is a coarse grep rather than parsing internals.
# kamal will refuse to deploy on a real conflict — this is just an early heads-up.
DEPLOY_DOMAIN=$(awk '/^proxy:/{in_p=1;next} /^[a-zA-Z]/{in_p=0} in_p && /^  host:/{print $2; exit}' \
    config/deploy.yml 2>/dev/null || true)
if [[ -n "$DEPLOY_DOMAIN" ]]; then
    existing_hit=$(ssh "${HETZNER_ADMIN_USER}@${HETZNER_HOST}" \
        "docker ps --format '{{.Names}}\t{{.Image}}\t{{.Labels}}' 2>/dev/null \
            | grep -F '$DEPLOY_DOMAIN' | grep -v '$KAMAL_USER' | head -3" || true)
    if [[ -n "$existing_hit" ]]; then
        echo "    ! Warning: $DEPLOY_DOMAIN appears in another container's labels:"
        while IFS= read -r line; do echo "         $line"; done <<< "$existing_hit"
        echo "      kamal will refuse to deploy on a real conflict; if not, false"
        echo "      positive (shared label string). Continuing."
    fi
fi
echo ""

# --- Planned changes summary + confirmation --------------------------------

echo "Planned changes for __PROJECT__ on $HETZNER_HOST:"
echo "  - useradd $KAMAL_USER (in docker group)"
echo "  - install ${DEPLOY_KEY}.pub into ${KAMAL_USER}'s authorized_keys"
echo "  - remove $HETZNER_ADMIN_USER from docker group (if currently a member)"
echo "  - decrypt $SECRETS_AGE_FILE locally (shredded on exit)"
echo "  - docker login to the registry from this machine (logged out on exit)"
echo "  - kamal setup (deploys initial container, configures kamal-proxy)"
echo ""
read -r -p "Proceed? [y/N] " bootstrap_confirm
if [[ ! "${bootstrap_confirm,,}" =~ ^y ]]; then
    echo "Aborted."
    exit 0
fi
echo ""

# --- 1+2. Create kamal user, install deploy key (idempotent) ----------------

echo "[1/4] Creating $KAMAL_USER on Hetzner..."

ssh "${HETZNER_ADMIN_USER}@${HETZNER_HOST}" \
    "DEPLOY_PUBKEY='${DEPLOY_PUBKEY}' KAMAL_USER='${KAMAL_USER}' bash -s" << 'REMOTE'
set -euo pipefail

if ! id "$KAMAL_USER" &>/dev/null; then
    sudo useradd -m -s /bin/bash "$KAMAL_USER"
fi

if ! id -nG "$KAMAL_USER" | grep -qw docker; then
    sudo usermod -aG docker "$KAMAL_USER"
fi

sudo mkdir -p "/home/${KAMAL_USER}/.ssh"
echo "$DEPLOY_PUBKEY" | sudo tee "/home/${KAMAL_USER}/.ssh/authorized_keys" >/dev/null
sudo chmod 700 "/home/${KAMAL_USER}/.ssh"
sudo chmod 600 "/home/${KAMAL_USER}/.ssh/authorized_keys"
sudo chown -R "${KAMAL_USER}:${KAMAL_USER}" "/home/${KAMAL_USER}/.ssh"
REMOTE

echo "    ✓ User $KAMAL_USER ready"

if ! ssh -o StrictHostKeyChecking=accept-new -i "$DEPLOY_KEY" \
        "${KAMAL_USER}@${HETZNER_HOST}" "true" 2>/dev/null; then
    echo "    ✗ Deploy key auth as $KAMAL_USER failed"
    exit 1
fi
echo "    ✓ Deploy key authenticates as $KAMAL_USER"

# --- 3. Remove admin from docker group --------------------------------------

echo "[2/4] Tightening admin user privileges..."

ssh "${HETZNER_ADMIN_USER}@${HETZNER_HOST}" \
    "HETZNER_ADMIN_USER='${HETZNER_ADMIN_USER}' bash -s" << 'REMOTE'
set -euo pipefail
if id -nG "$HETZNER_ADMIN_USER" | grep -qw docker; then
    sudo gpasswd -d "$HETZNER_ADMIN_USER" docker >/dev/null
    echo "    ✓ Removed $HETZNER_ADMIN_USER from docker group"
else
    echo "    ✓ $HETZNER_ADMIN_USER already not in docker group"
fi
REMOTE

# --- 4a. Decrypt secrets and load into env ---------------------------------

if [[ -f "$SECRETS_AGE_FILE" ]]; then
    echo "[3/4] Decrypting secrets from $SECRETS_AGE_FILE..."
    age -d "$SECRETS_AGE_FILE" > "$SECRETS_PLAIN_FILE"
    chmod 600 "$SECRETS_PLAIN_FILE"
elif [[ -f "$SECRETS_PLAIN_FILE" ]]; then
    echo "[3/4] Using plaintext $SECRETS_PLAIN_FILE (consider encrypting to .age)..."
fi

if [[ -f "$SECRETS_PLAIN_FILE" ]]; then
    set -a
    # shellcheck disable=SC1090
    source "$SECRETS_PLAIN_FILE"
    set +a
fi

# --- 4b. Docker login on dev VM (so buildx can forward creds to buildkit) ---
# Kamal's own docker login runs on the deploy target, not on the build host.
# When using builder.remote, buildx on the dev VM forwards credentials from
# its local ~/.docker/config.json to the remote buildkit container. So we
# need to ensure the dev VM is logged in before kamal setup runs.

if [[ -n "${KAMAL_REGISTRY_PASSWORD:-}" ]] && [[ -f "config/deploy.yml" ]]; then
    REGISTRY_SERVER=$(awk '/^registry:/{in_r=1;next} /^[a-zA-Z]/{in_r=0} in_r && /^  server:/{print $2; exit}' config/deploy.yml)
    REGISTRY_USERNAME=$(awk '/^registry:/{in_r=1;next} /^[a-zA-Z]/{in_r=0} in_r && /^  username:/{print $2; exit}' config/deploy.yml)
    if [[ -n "$REGISTRY_SERVER" && -n "$REGISTRY_USERNAME" ]]; then
        echo "    Logging in to $REGISTRY_SERVER as $REGISTRY_USERNAME..."
        echo "$KAMAL_REGISTRY_PASSWORD" | docker login "$REGISTRY_SERVER" -u "$REGISTRY_USERNAME" --password-stdin >/dev/null
        LOGGED_IN_REGISTRY="$REGISTRY_SERVER"
        echo "    ✓ Logged in (will be logged out on exit)"
    fi
fi

# --- 4c. Run kamal setup ---------------------------------------------------

echo ""
echo "[4/4] Running 'kamal setup' (installs proxy, requests cert, builds, deploys)..."
echo "      May take several minutes."

# APP_VERSION is baked into the image via builder.args (see config/deploy.yml)
# so the running container can report what it was deployed from. For
# bootstrap (no explicit tag), use git describe — it picks the most recent
# tag, or falls back to a short SHA, or "initial" if neither is available.
export APP_VERSION="$(git describe --tags --always --dirty 2>/dev/null || echo initial)"
echo "    Building with APP_VERSION=$APP_VERSION"

kamal setup

echo ""
echo "✓ __PROJECT__ bootstrapped and deployed."
echo "  Verify: curl https://<your-domain-from-deploy.yml>"
